  <!-- Copy all plugin DLLs to publish directory after publish -->
  <Target Name="CopyApplicationPlugins" AfterTargets="Publish">
    <ItemGroup>
      <!-- ApplicationPlugins -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../ApplicationPlugins/LoadRegions/bin/$(Configuration)/OpenSim.ApplicationPlugins.LoadRegions.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../ApplicationPlugins/RegionModulesController/bin/$(Configuration)/OpenSim.ApplicationPlugins.RegionModulesController.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../ApplicationPlugins/RemoteController/bin/$(Configuration)/OpenSim.ApplicationPlugins.RemoteController.dll" />
      <!-- Data providers -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../Data/Null/bin/$(Configuration)/OpenSim.Data.Null.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../Data/PGSQL/bin/$(Configuration)/OpenSim.Data.PGSQL.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../Data/SQLite/bin/$(Configuration)/OpenSim.Data.SQLite.dll" />
      <!-- Physics modules -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../PhysicsModules/BasicPhysics/bin/$(Configuration)/OpenSim.Region.PhysicsModule.BasicPhysics.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../PhysicsModules/BulletS/bin/$(Configuration)/OpenSim.Region.PhysicsModule.BulletS.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../PhysicsModules/ConvexDecompositionDotNet/bin/$(Configuration)/OpenSim.Region.PhysicsModules.ConvexDecompositionDotNet.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../PhysicsModules/Meshing/bin/$(Configuration)/OpenSim.Region.PhysicsModule.Meshing.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../PhysicsModules/POS/bin/$(Configuration)/OpenSim.Region.PhysicsModule.POS.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../PhysicsModules/ubOde/bin/$(Configuration)/OpenSim.Region.PhysicsModule.ubOde.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../PhysicsModules/ubOdeMeshing/bin/$(Configuration)/OpenSim.Region.PhysicsModule.ubOdeMeshing.dll" />
      <!-- Addons -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../Addons/Groups/bin/$(Configuration)/OpenSim.Addons.Groups.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../Addons/OfflineIM/bin/$(Configuration)/OpenSim.Addons.OfflineIM.dll" />
      <!-- ClientStack -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../ClientStack/Linden/Caps/bin/$(Configuration)/OpenSim.Region.ClientStack.LindenCaps.dll" />
      <!-- Capabilities Handlers -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../Capabilities/Handlers/bin/$(Configuration)/OpenSim.Capabilities.Handlers.dll" />
      <!-- Script Engine -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../ScriptEngine/Shared/bin/$(Configuration)/OpenSim.Region.ScriptEngine.Shared.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../ScriptEngine/Shared/Api/Runtime/bin/$(Configuration)/OpenSim.Region.ScriptEngine.Shared.Api.Runtime.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../ScriptEngine/Shared/Api/Implementation/bin/$(Configuration)/OpenSim.Region.ScriptEngine.Shared.Api.dll" />
      <PluginFiles Include="$(MSBuildThisFileDirectory)../ScriptEngine/YEngine/bin/$(Configuration)/OpenSim.Region.ScriptEngine.YEngine.dll" />
      <!-- Optional modules -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../OptionalModules/bin/$(Configuration)/OpenSim.Region.OptionalModules.dll" />
      <!-- Currency module from addon-modules -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../../addon-modules/akkimoney_module/Modules/bin/$(Configuration)/OpenSim.Modules.Currency.dll" />
      <!-- AssetLoader -->
      <PluginFiles Include="$(MSBuildThisFileDirectory)../../Framework/AssetLoader/Filesystem/bin/$(Configuration)/OpenSim.Framework.AssetLoader.Filesystem.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(PluginFiles)" DestinationFolder="$(PublishDir)" SkipUnchangedFiles="true" />
    <Message Text="Copied all plugin DLLs to $(PublishDir)" Importance="high" />
  </Target>

